{
  "name": "stargazers-action",
  "version": "0.1.0",
  "private": true,
  "description": "Generate recent GitHub stargazer JSON and RSS feeds for static sites",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/index.cjs",
    "lint": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@actions/core": "1.11.1",
    "yaml": "2.8.1"
  },
  "devDependencies": {
    "@types/node": "22.15.21",
    "esbuild": "0.25.4",
    "tsx": "4.20.3",
    "typescript": "5.8.3"
  }
}
