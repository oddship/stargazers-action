{
  "name": "stargazers-action",
  "version": "0.2.0",
  "private": true,
  "description": "Generate GitHub stargazer feeds and optional Discord notifications for sites, scripts, and GitHub Actions",
  "type": "module",
  "exports": {
    ".": "./dist/lib.js"
  },
  "bin": {
    "stargazers": "./dist/cli.cjs"
  },
  "scripts": {
    "build:action": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node24 --outfile=dist/index.cjs",
    "build:lib": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node24 --outfile=dist/lib.js",
    "build:cli": "esbuild src/cli.ts --bundle --platform=node --format=cjs --target=node24 --banner:js=#!/usr/bin/env\\ node --outfile=dist/cli.cjs",
    "build": "npm run build:action && npm run build:lib && npm run build:cli",
    "lint": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@actions/core": "1.11.1",
    "yaml": "2.8.1"
  },
  "devDependencies": {
    "@types/node": "22.15.21",
    "esbuild": "0.25.4",
    "tsx": "4.20.3",
    "typescript": "5.8.3"
  }
}
